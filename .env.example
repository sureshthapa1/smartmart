# ════════════════════════════════════════════════════════════════════
# GoldKernel SmartMart — Environment Variables
# Copy this file to .env and fill in your real values before running.
# All REQUIRED keys must be set for the app to start in production.
# ════════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-32-byte-hex-random-string
FLASK_ENV=production

# ── Admin account ────────────────────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password   # REQUIRED

# ── Database (PostgreSQL on Render, SQLite for local dev) ────────────
DATABASE_URL=postgresql://user:password@host:5432/smartmart   # REQUIRED in production

# ── AI — Claude API (chatbot, autofill, daily summary, price tips) ───
GEMINI_API_KEY=AIza...          # REQUIRED for AI chat, product autofill, image recognition,
                                 # daily report narrative, order confirmation emails, smart search
ANTHROPIC_API_KEY=sk-ant-...    # Optional — powers Business Advisor commentary, review
                                 # auto-classification, MCP AI chat tool, and price-justification
                                 # badges. These features fall back gracefully if unset.

# ── Cloudinary (persistent image storage across Render redeploys) ────
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME   # REQUIRED in production

# ── Redis (shared rate-limiting + caching across Gunicorn workers) ───
# Required for production to share rate limit state across workers.
# On Render: add a Redis service, copy the Internal Redis URL here.
# Leave blank for local dev — falls back to in-memory (single worker only).
REDIS_URL=redis://localhost:6379/0   # Auto-set by Render when Redis service added

# ── Email (order confirmations, password resets, alerts) ─────────────
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password      # Gmail App Password (not account password)
MAIL_DEFAULT_SENDER=GoldKernel <noreply@yourdomain.com>

# ── SMS Notifications (Sparrow SMS — Nepal) ──────────────────────────
# Get token from sparrowsms.com. Set provider to 'none' if token is blank.
NOTIFICATION_PROVIDER=sparrow        # Options: sparrow | none
SPARROW_TOKEN=your-sparrow-token     # Get from sparrowsms.com

# ── eSewa Payment Gateway ────────────────────────────────────────────
ESEWA_PRODUCT_CODE=EPAYTEST          # Use EPAYTEST for sandbox, live code for production
ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q    # Sandbox secret — replace with live secret in production

# ── Khalti Payment Gateway ───────────────────────────────────────────
KHALTI_SECRET_KEY=test_secret_key_...   # Get from khalti.com developer portal

# ── App URL (used by cron bot for self-calling) ──────────────────────
APP_URL=https://smart-mart.onrender.com  # Your Render URL

# ── Bot security (webhook secret for /api/bot/run endpoint) ──────────
BOT_SECRET=change-me-random-secret

# ── Pexels API (AI product image search during autofill) ─────────────
PEXELS_API_KEY=your-pexels-api-key   # Free at pexels.com/api

# ── Log level ────────────────────────────────────────────────────────
LOG_LEVEL=INFO
