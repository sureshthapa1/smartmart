# ─────────────────────────────────────────────────────────────────────────────
# SmartMart — Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git (it is already in .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ── Flask core ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-32-byte-hex-string

# "development" | "production" | "testing"
FLASK_ENV=development

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank for SQLite (dev). In production set to your PostgreSQL URL.
# Render provides this automatically when you link a Postgres database.
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Admin account (used by seed.py and build.sh) ─────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-to-a-secure-password

# ── AI / Anthropic ───────────────────────────────────────────────────────────
# Required for Claude-powered features. Get key at https://console.anthropic.com
# ANTHROPIC_API_KEY=sk-ant-...

# ── eSewa Payment Gateway ────────────────────────────────────────────────────
# Sandbox: product code = EPAYTEST, secret = 8gBm/:&EnhH.1/q (eSewa default)
# Production: get your merchant credentials from eSewa merchant portal
# ESEWA_PRODUCT_CODE=EPAYTEST
# ESEWA_SECRET_KEY=8gBm/:&EnhH.1/q

# ── Khalti Payment Gateway ───────────────────────────────────────────────────
# Get live secret key from https://merchant.khalti.com
# KHALTI_SECRET_KEY=live_secret_key_...

# ── Notifications (SMS/WhatsApp) ─────────────────────────────────────────────
# Provider: "sparrow" (Nepal SMS) | "twilio" | "none" (log-only, default)
# NOTIFICATION_PROVIDER=sparrow
# SPARROW_TOKEN=your-sparrow-token
#
# For Twilio:
# TWILIO_SID=ACxxxxxxx
# TWILIO_TOKEN=your-auth-token
# TWILIO_FROM=+977XXXXXXXXXX

# ── Email (Flask-Mail) ───────────────────────────────────────────────────────
# Used for order confirmation emails and password reset.
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=your-email@gmail.com
# MAIL_PASSWORD=your-app-password
# MAIL_DEFAULT_SENDER=GoldKernel <your-email@gmail.com>

# ── Cloudinary (persistent image storage) ───────────────────────────────────
# Without this, uploaded images are lost on each Render redeploy.
# Get free account at https://cloudinary.com
# CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# ── Redis (optional but recommended for production) ──────────────────────────
# Enables shared rate-limiting and caching across Gunicorn workers.
# Add a Redis service in Render dashboard, then set:
# REDIS_URL=redis://localhost:6379/0

# ── Scheduled bots ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(24))"
# BOT_SECRET=change-me-to-a-random-value

# ── App URL (used by cron service to call itself) ────────────────────────────
# APP_URL=https://your-app.onrender.com

# ── Optional tuning ──────────────────────────────────────────────────────────
# Dashboard/BI cache TTL in seconds (default 180)
# DASHBOARD_CACHE_TTL=180

# Log level: DEBUG | INFO | WARNING | ERROR
# LOG_LEVEL=INFO
